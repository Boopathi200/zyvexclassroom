# Dependencies
node_modules/

# Environment & secrets (never commit real env files)
.env
server/.env
client/.env
client/.env.local

# Build output
client/dist/
server/dist/

# Uploads & user-generated media (keep only .gitkeep)
server/uploads/*
!server/uploads/.gitkeep
server/uploads/videos/*
!server/uploads/videos/.gitkeep

# Logs & debug
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# OS
.DS_Store
Thumbs.db
Desktop.ini

# IDE
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Test / coverage
coverage/
.nyc_output/

# Misc
.cache/
